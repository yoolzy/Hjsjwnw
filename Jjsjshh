--//main gun system

-- RPG-7 specific variables
local rpgRocket = nil
local rpgBolt = nil
local rpgBoltVisible = true
local rpgFired = false
local rpgReloading = false

local function Fire(mouse)
	if not character or not character:FindFirstChild("Head") then return end

	-- RPG-7 special handling
	if wepin and wepin.Name == "RPG-7" then
		if rpgFired then return end -- Only 1 shot before reload
		if rpgReloading then return end

		rpgFired = true
		rpgBoltVisible = false

		local origin = camera.CFrame.Position
		local target = mouse.Hit.Position
		local direction = (target - origin).Unit

		-- Find the bolt part in the tool
		local tool = character:FindFirstChild("RPG-7")
		if tool then
			rpgBolt = tool:FindFirstChild("bolt", true) or tool:FindFirstChild("Bolt", true)
		end

		-- Create rocket projectile
		local rocket = Instance.new("Part")
		rocket.Name = "Rocket"
		rocket.Size = Vector3.new(0.3, 0.3, 1.5)
		rocket.Color = Color3.new(0.2, 0.2, 0.2)
		rocket.Material = Enum.Material.Metal
		rocket.CFrame = CFrame.new(origin, origin + direction)
		rocket.Parent = Ignore_Model

		local rocketMesh = Instance.new("SpecialMesh", rocket)
		rocketMesh.MeshType = Enum.MeshType.Cylinder

		-- Detach and launch the bolt if it exists
		if rpgBolt then
			local boltClone = rpgBolt:Clone()
			boltClone.Anchored = false
			boltClone.CanCollide = true
			boltClone.Parent = Ignore_Model

			-- Weld all bolt children to the clone
			for _, child in ipairs(rpgBolt:GetChildren()) do
				if child:IsA("BasePart") then
					local w = Instance.new("Weld")
					w.Part0 = boltClone
					w.Part1 = child
					w.Parent = boltClone
					child.Anchored = false
					child.CanCollide = true
				end
			end

			-- Hide original bolt
			rpgBolt.Transparency = 1
			for _, child in ipairs(rpgBolt:GetChildren()) do
				if child:IsA("BasePart") then
					child.Transparency = 1
				end
			end

			-- Launch bolt toward target
			local bodyVelocity = Instance.new("BodyVelocity", boltClone)
			bodyVelocity.Velocity = direction * 200
			bodyVelocity.MaxForce = Vector3.new(50000, 50000, 50000)

			-- Tween bolt to target position
			local distance = (target - origin).Magnitude
			local travelTime = distance / 200

			TweenService:Create(boltClone, TweenInfo.new(travelTime, Enum.EasingStyle.Linear), {
				Position = target
			}):Play()

			-- Explosion when bolt reaches target
			delay(travelTime, function()
				-- Explosion effect
				local explosion = Instance.new("Explosion")
				explosion.Position = boltClone.Position
				explosion.BlastRadius = 12
				explosion.BlastPressure = 500000
				explosion.Parent = workspace

				-- Unanchor parts in blast radius
				local blastRegion = Region3.new(boltClone.Position - Vector3.new(12, 12, 12), boltClone.Position + Vector3.new(12, 12, 12))
				local parts = workspace:FindPartsInRegion3(blastRegion, nil, 100)

				for _, part in ipairs(parts) do
					if part:IsA("BasePart") and not part:IsDescendantOf(character) then
						part.Anchored = false
						part.CanCollide = true

						-- Add slight velocity to unanchored parts
						local bodyVel = Instance.new("BodyVelocity", part)
						bodyVel.Velocity = (part.Position - boltClone.Position).Unit * 50 + Vector3.new(0, 30, 0)
						bodyVel.MaxForce = Vector3.new(50000, 50000, 50000)
						game.Debris:AddItem(bodyVel, 0.2)
					end
				end

				-- INSTANT KILL - Hitkill all humans in radius
				for _, model in ipairs(workspace:GetChildren()) do
					if model:IsA("Model") and model ~= character then
						local humanoid = model:FindFirstChild("Humanoid")
						local rootPart = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Torso")
						if humanoid and rootPart then
							local dist = (rootPart.Position - boltClone.Position).Magnitude
							if dist <= 12 then
								humanoid.Health = 0 -- INSTANT KILL
							end
						end
					end
				end

				-- Explosion visual
				local expPart = Instance.new("Part")
				expPart.Size = Vector3.new(1, 1, 1)
				expPart.Position = boltClone.Position
				expPart.Anchored = true
				expPart.CanCollide = false
				expPart.Transparency = 0.5
				expPart.Color = Color3.new(1, 0.5, 0)
				expPart.Material = Enum.Material.Neon
				expPart.Parent = Ignore_Model

				TweenService:Create(expPart, TweenInfo.new(0.3), {
					Size = Vector3.new(8, 8, 8),
					Transparency = 1
				}):Play()
				game.Debris:AddItem(expPart, 0.5)

				-- Clean up bolt
				boltClone:Destroy()
			end)
		end

		-- Also fire the rocket visual
		local bodyVelocity = Instance.new("BodyVelocity", rocket)
		bodyVelocity.Velocity = direction * 300
		bodyVelocity.MaxForce = Vector3.new(50000, 50000, 50000)

		game.Debris:AddItem(rocket, 3)

		return
	end

	-- Normal gun fire
	local origin = camera.CFrame.Position
	local target = mouse.Hit.Position

	local direction = (target - origin).Unit * 1000

	local rayParams = RaycastParams.new()
	rayParams.FilterDescendantsInstances = {character, Ignore_Model}
	rayParams.FilterType = Enum.RaycastFilterType.Blacklist
	rayParams.IgnoreWater = true

	local result = workspace:Raycast(origin, direction, rayParams)

	if result then
		local hit = result.Instance
		local pos = result.Position

		local model = hit:FindFirstAncestorOfClass("Model")
		if model and model:FindFirstChild("Humanoid") then
			local humanoid = model:FindFirstChild("Humanoid")

			if hit.Name == "Head" then
				humanoid:TakeDamage(math.random(Settings.HeadShotDamage[1], Settings.HeadShotDamage[2]))
			else
				humanoid:TakeDamage(math.random(Settings.Damage[1], Settings.Damage[2]))
			end

		else
			local hole = Instance.new("Part")
			hole.Size = Vector3.new(0.2, 0.2, 0.01)
			hole.Anchored = true
			hole.CanCollide = false
			hole.Color = Color3.new(0,0,0)
			hole.Material = Enum.Material.SmoothPlastic

			hole.CFrame = CFrame.new(pos, pos + result.Normal)

			hole.Parent = Ignore_Model
			game.Debris:AddItem(hole, 5)
		end
	end
end

-- RPG-7 Reload function
local function reloadRPG()
	if not wepin or wepin.Name ~= "RPG-7" then return end
	if not rpgFired then return end
	if rpgReloading then return end

	rpgReloading = true

	-- Reload animation delay
	wait(2)

	-- Restore bolt visibility
	if rpgBolt then
		rpgBolt.Transparency = 0
		for _, child in ipairs(rpgBolt:GetChildren()) do
			if child:IsA("BasePart") then
				child.Transparency = 0
			end
		end
	end

	rpgFired = false
	rpgBoltVisible = true
	rpgReloading = false
end

local function aimanim()
	if not reloading and not running and equipped then
		aiming = true
		game.Workspace.CurrentCamera.FieldOfView = 45
	end
end

local function unaimanim()
	aiming = false
	game.Workspace.CurrentCamera.FieldOfView = 70
end

mouse.Button2Down:Connect(aimanim)
mouse.Button2Up:Connect(unaimanim)

--//main character functions

local function carms(tool)
	local char = player.Character
	if char and not Arms_Made then
		Arms_Made = true
		local Torso = char:FindFirstChild("Torso")
		if Torso and Torso:FindFirstChild("Right Shoulder") then
			Torso["Right Shoulder"].Part1 = nil
		end

		Left_Weld = Instance.new("Weld")
		Left_Weld.Name = "Left_Weld"
		Left_Weld.Part0 = char:WaitForChild("Head")
		Left_Weld.C0 = CFrame.new(0.4, -1.5, 0)
		Left_Weld.Parent = Torso

		local leftArm = char:FindFirstChild("Left Arm")
		if leftArm then
			if Torso and Torso:FindFirstChild("Left Shoulder") then
				Torso["Left Shoulder"].Part1 = nil
			end
			Left_Weld.Part1 = leftArm
		end

		Right_Weld = Instance.new("Weld")
		Right_Weld.Name = "Right_Weld"
		Right_Weld.Part0 = char:WaitForChild("Head")
		Right_Weld.Part1 = char:WaitForChild("Right Arm")
		Right_Weld.C0 = CFrame.new(0, -1.4, -0.2)
		Right_Weld.Parent = Torso

		Left_Weld.C1 = Settings.LeftPos
		Right_Weld.C1 = Settings.RightPos
	end

	if Settings.FakeArms and not Fake_Arm_Right then
		local rightArm = char:FindFirstChild("Right Arm")
		local leftArm = char:FindFirstChild("Left Arm")
		if rightArm and leftArm then
			Fake_Arm_Right = rightArm:Clone()
			Fake_Arm_Left = leftArm:Clone()
			Fake_Arm_Right.Size = Vector3.new()
			Fake_Arm_Left.Size = Vector3.new()

			local w1 = Instance.new("Weld", Fake_Arm_Right)
			w1.Part0 = rightArm
			w1.Part1 = Fake_Arm_Right
			Fake_Arm_Right.Transparency = Settings.FakeArmTransparency

			local w2 = Instance.new("Weld", Fake_Arm_Left)
			w2.Part0 = leftArm
			w2.Part1 = Fake_Arm_Left
			Fake_Arm_Left.Transparency = Settings.FakeArmTransparency

			Fake_Arm_Model = Instance.new("Model", camera)
			Fake_Arm_Model.Name = "FakeArms"
			Fake_Arm_Right.Parent = Fake_Arm_Model
			Fake_Arm_Left.Parent = Fake_Arm_Model

			local shirt = char:FindFirstChild("Shirt")
			if shirt then
				Instance.new("Humanoid", Fake_Arm_Model)
				shirt:Clone().Parent = Fake_Arm_Model
			end
		end
	end
end

local function rarms()
	local char = player.Character
	if Fake_Arm_Model then
		Fake_Arm_Model:Destroy()
		Fake_Arm_Right = nil
		Fake_Arm_Left = nil
		Fake_Arm_Model = nil
	end
	if char and Left_Weld and Right_Weld then
		Arms_Made = false
		local Torso = char:FindFirstChild("Torso")
		if Torso then
			local rs = Torso:FindFirstChild("Right Shoulder")
			local ls = Torso:FindFirstChild("Left Shoulder")
			if rs then rs.Part1 = char:FindFirstChild("Right Arm") end
			if ls then ls.Part1 = char:FindFirstChild("Left Arm") end
		end
		Left_Weld:Destroy()
		Right_Weld:Destroy()
		Left_Weld = nil
		Right_Weld = nil
	end
end

local function updateneck()
	if not IsEquipped then return end
	local char = player.Character
	local dist = (camera.Focus.Position - camera.CoordinateFrame.Position).magnitude
	local Torso = char:FindFirstChild("Torso")
	if Torso and Torso:FindFirstChild("Neck") then
		-- CABEÇA NÃO SE MOVE - pescoço sempre na posição padrão
		mouse.TargetFilter = nil
		Torso.Neck.C0 = CFrame.new(0, 1, 0, -1, 0, 0, 0, 0, 1, 0, 1, 0)
		Torso.Neck.C1 = CFrame.new(0, -0.5, 0, -1, 0, 0, 0, 0, 1, 0, 1, 0)
	end
end

--// back modelssml

local backModels = {}

local function createBackModel(toolName, modelTemplate, side)
	side = side or 1

	if backModels[toolName] then
		backModels[toolName]:Destroy()
		backModels[toolName] = nil
	end

	local char = player.Character
	if not char then return end

	local torso = char:FindFirstChild("Torso")
	if not torso then return end

	local backModel = modelTemplate:Clone()
	backModel.Name = toolName .. "_Back"

	local parts = {}
	for _, obj in ipairs(backModel:GetChildren()) do
		if obj:IsA("BasePart") then
			obj.Anchored = false
			obj.CanCollide = false
			table.insert(parts, obj)
		end
	end

	local handle = backModel:FindFirstChild("Handle")
		or backModel:FindFirstChild("Body")
		or backModel:FindFirstChildOfClass("BasePart")

	if handle then
		handle.Name = "Handle"
		for _, part in ipairs(parts) do
			if part ~= handle then
				local weld = Instance.new("WeldConstraint")
				weld.Part0 = handle
				weld.Part1 = part
				weld.Parent = handle
			end
		end
	end

	-- Hide bolt on back model if RPG-7 was fired and not reloaded
	if toolName == "RPG-7" and not rpgBoltVisible then
		local backBolt = backModel:FindFirstChild("bolt", true) or backModel:FindFirstChild("Bolt", true)
		if backBolt then
			backBolt.Transparency = 1
			for _, child in ipairs(backBolt:GetChildren()) do
				if child:IsA("BasePart") then
					child.Transparency = 1
				end
			end
		end
	end

	if handle then
		local backWeld = Instance.new("Weld")
		backWeld.Name = "BackWeld_" .. toolName
		backWeld.Part0 = torso
		backWeld.Part1 = handle

		if side == 1 then
			backWeld.C0 = CFrame.new(0.5, 0.4, 1.1) * CFrame.Angles(math.rad(90), math.rad(360), 15.7)
		else
			backWeld.C0 = CFrame.new(-0.5, 0.4, 1.1) * CFrame.Angles(math.rad(90), math.rad(360), -15.7)
		end

		backWeld.Parent = torso
	end

	backModel.Parent = char
	backModels[toolName] = backModel
end

local function removeBackModel(toolName)
	if backModels[toolName] then
		backModels[toolName]:Destroy()
		backModels[toolName] = nil
	end
end

--// idk how to name this

local function countGuns()
	local count = 0
	if wepin1 ~= nil then count = count + 1 end
	if wepin2 ~= nil then count = count + 1 end
	return count
end

local function destroyGunSlot(slot)
	if slot == 1 and wepin1 then
		local oldbackpack = player.Backpack:FindFirstChild(wepin1)
		local oldchar = character:FindFirstChild(wepin1)
		if oldbackpack then oldbackpack:Destroy() end
		if oldchar then oldchar:Destroy() end
		removeBackModel(wepin1)
		wepin1 = nil
	elseif slot == 2 and wepin2 then
		local oldbackpack = player.Backpack:FindFirstChild(wepin2)
		local oldchar = character:FindFirstChild(wepin2)
		if oldbackpack then oldbackpack:Destroy() end
		if oldchar then oldchar:Destroy() end
		removeBackModel(wepin2)
		wepin2 = nil
	end
end

local function updateGUI()
	W1.Text = wepin1 or ""
	W2.Text = wepin2 or ""

	if currentSlot == 1 then
		W1.BackgroundColor3 = Color3.fromRGB(85, 170, 85)
		W2.BackgroundColor3 = Color3.fromRGB(34, 34, 34)
	else
		W1.BackgroundColor3 = Color3.fromRGB(34, 34, 34)
		W2.BackgroundColor3 = Color3.fromRGB(85, 170, 85)
	end
end

local function switchGun()
	if currentSlot == 1 then
		currentSlot = 2
	else
		currentSlot = 1
	end
	updateGUI()

	local targetGun = currentSlot == 1 and wepin1 or wepin2
	if targetGun then
		local tool = player.Backpack:FindFirstChild(targetGun)
		if tool then
			tool.Parent = character
		end
	end
end

--//itemspawn itesm

local y = 0

local wepinfol = game.ReplicatedStorage:WaitForChild("StummyModels"):WaitForChild("Items")

local function wepons()
	ItemSpawn:ClearAllChildren()
	y = 0
	local children = wepinfol:GetChildren()

	table.sort(children, function(a, b)
		return a.Name:lower() < b.Name:lower()
	end)

	for _, item in ipairs(children) do
		local b = Instance.new("TextButton")
		b.Name = item.Name
		b.Parent = ItemSpawn
		b.BackgroundColor3 = Color3.fromRGB(34, 34, 34)
		b.BorderColor3 = Color3.fromRGB(85, 85, 85)
		b.BorderSizePixel = 3
		b.Size = UDim2.new(0, 88, 0, 30)
		b.Position = UDim2.new(0, 0, 0, y)
		b.Font = Enum.Font.GothamBold
		b.Text = item.Name
		b.TextColor3 = Color3.fromRGB(255, 255, 255)
		b.TextScaled = true
		b.TextSize = 14
		b.TextWrapped = true
		y = y + 30

		if ItemSpawn:IsA("ScrollingFrame") then
			ItemSpawn.CanvasSize = UDim2.new(0, 0, 0, y)
		end

		b.MouseButton1Click:Connect(function()
			local model = wepinfol:FindFirstChild(item.Name)
			local itemType = getItemType(item.Name)

			if not model then return end

			if currentSlot == 1 and item.Name == wepin1 then
				destroyGunSlot(1)
				updateGUI()
				return
			end

			if currentSlot == 2 and item.Name == wepin2 then
				destroyGunSlot(2)
				updateGUI()
				return
			end

			if currentSlot == 1 and item.Name == wepin2 then
				currentSlot = 2
				updateGUI()
				local tool = player.Backpack:FindFirstChild(wepin2)
				if tool then tool.Parent = character end
				return
			end

			if currentSlot == 2 and item.Name == wepin1 then
				currentSlot = 1
				updateGUI()
				local tool = player.Backpack:FindFirstChild(wepin1)
				if tool then tool.Parent = character end
				return
			end

			local gunCount = countGuns()
			if gunCount >= 2 then
				destroyGunSlot(currentSlot)
			end

			local targetSlot
			if wepin1 == nil then
				targetSlot = 1
			elseif wepin2 == nil then
				targetSlot = 2
			else
				targetSlot = currentSlot
			end

			if targetSlot == 1 then
				wepin1 = item.Name
			else
				wepin2 = item.Name
			end

			if itemType == "gun" then
				createBackModel(item.Name, model, targetSlot)
			end

			if itemType == "gun" then
				local aimparter = model:FindFirstChild("AimPart")
				if aimparter then
					Settings.AimPart = aimparter
				else
					Settings.AimPart = model:FindFirstChild("Handle") or model:FindFirstChildOfClass("BasePart")
				end
			end

			local guntool = Instance.new("Tool")
			guntool.Name = item.Name
			guntool.CanBeDropped = false
			guntool.RequiresHandle = true

			local modelClone = model:Clone()
			local parts = {}

			for _, obj in ipairs(modelClone:GetChildren()) do
				if obj:IsA("BasePart") then
					obj.Anchored = false
					obj.CanCollide = false
					table.insert(parts, obj)
				end
				obj.Parent = guntool
			end

			local handle = guntool:FindFirstChild("Handle")
				or guntool:FindFirstChild("Body")
				or guntool:FindFirstChildOfClass("BasePart")

			if handle then
				handle.Name = "Handle"
				for _, part in ipairs(parts) do
					if part ~= handle then
						local weld = Instance.new("WeldConstraint")
						weld.Part0 = handle
						weld.Part1 = part
						weld.Parent = handle
					end
				end
			end

			guntool.Equipped:Connect(function()
				wepin = guntool
				IsEquipped = true
				if itemType == "gun" then
					removeBackModel(guntool.Name)
				end

				if itemType == "gun" then
					carms(guntool)
					RunService:BindToRenderStep("neckupdate", Enum.RenderPriority.Camera.Value + 1, updateneck)
				elseif itemType == "melee" then
					print("Equipped melee:", item.Name)
				elseif itemType == "food" then
					print("Equipped food:", item.Name)
				end
			end)

			guntool.Unequipped:Connect(function()
				wepin = nil
				IsEquipped = false

				-- Reset RPG-7 state when unequipped
				if guntool.Name == "RPG-7" then
					-- Don't reset rpgFired or rpgBoltVisible here - keep them as they are
					-- So if fired without reload, bolt stays hidden on back
					rpgReloading = false
				end

				if itemType == "gun" then
					local originalModel = wepinfol:FindFirstChild(guntool.Name)
					if originalModel then
						local slotNum = (wepin1 == guntool.Name) and 1 or 2
						createBackModel(guntool.Name, originalModel, slotNum)
					end
				end

				if itemType == "gun" then
					rarms()
					RunService:UnbindFromRenderStep("neckupdate")

					local char = player.Character
					if char then
						local Torso = char:FindFirstChild("Torso")
						if Torso and Torso:FindFirstChild("Neck") then
							Torso.Neck.C0 = CFrame.new(0, 1, 0, -1, 0, 0, 0, 0, 1, 0, 1, 0)
							Torso.Neck.C1 = CFrame.new(0, -0.5, 0, -1, 0, 0, 0, 0, 1, 0, 1, 0)
						end
					end
				end
			end)

			guntool.Parent = player.Backpack

			currentSlot = targetSlot
			updateGUI()
		end)
	end
end

wepons()

