local function getItemType(name)
	for _, v in ipairs(guns) do
		if v == name then
			return "gun"
		end
	end

	for _, v in ipairs(melee) do
		if v == name then
			return "melee"
		end
	end

	for _, v in ipairs(food) do
		if v == name then
			return "food"
		end
	end

	return "unknown"
end

